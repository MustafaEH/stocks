# Database
# For local development, use your local PostgreSQL URL
# For production on Render, use the PostgreSQL connection string from Render dashboard
DATABASE_URL=postgresql://postgres:mustafa@localhost/stocksDB

# Security
# Generate a secure secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated)
# Example: http://localhost:5173,http://localhost:8080,https://yourfrontend.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080